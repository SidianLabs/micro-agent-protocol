{
  "title": "Async Execution Example - MAP Protocol",
  "description": "Demonstrates asynchronous task execution with polling and callbacks",
  "scenarios": [
    {
      "name": "Async Payment Processing",
      "description": "Long-running payment that requires async execution",
      "workflow": [
        {
          "step": 1,
          "action": "dispatch",
          "request": {
            "capability": "payment.process",
            "envelope": {
              "task_id": "async-pay-001",
              "requester_identity": { "type": "user", "id": "user-123", "tenant_id": "tenant-abc" },
              "target_agent": "agent-payment",
              "intent": "Process large batch payment",
              "constraints": {
                "common": {
                  "max_amount": 50000,
                  "resource_ids": ["batch-orders-001", "batch-orders-002"]
                }
              },
              "risk_class": "high",
              "delegation_token": "tok_batch_async",
              "requested_output_mode": "summary"
            },
            "negotiation": {
              "schema_version": "1.0.0",
              "delivery_mode": "async"
            }
          },
          "expected_response": {
            "status": "accepted",
            "result": {
              "task_id": "async-pay-001",
              "status": "running",
              "structured_output": {
                "execution_mode": "async",
                "estimated_completion": "2024-12-31T12:30:00Z",
                "batch_size": 1500,
                "progress_tracking_url": "/tasks/async-pay-001/progress"
              },
              "followup_required": true
            },
            "receipt": {
              "receipt_id": "receipt-async-001",
              "task_id": "async-pay-001",
              "agent_id": "agent-payment",
              "action_taken": "payment.process.async_initiated",
              "resource_touched": "batch/payment-queue",
              "policy_checks": ["batch_size_check", "threshold_approval"],
              "timestamp": "2024-12-31T12:00:00Z",
              "result_hash": "hash_async_001",
              "signature": "sig_async_001"
            }
          }
        },
        {
          "step": 2,
          "action": "poll_status",
          "request": {
            "task_id": "async-pay-001"
          },
          "expected_responses": [
            {
              "poll": 1,
              "response": {
                "task_id": "async-pay-001",
                "status": "running",
                "result": {
                  "progress": 25,
                  "processed": 375,
                  "failed": 0,
                  "estimated_completion": "2024-12-31T12:25:00Z"
                }
              }
            },
            {
              "poll": 2,
              "response": {
                "task_id": "async-pay-001",
                "status": "running",
                "result": {
                  "progress": 50,
                  "processed": 750,
                  "failed": 0,
                  "estimated_completion": "2024-12-31T12:20:00Z"
                }
              }
            },
            {
              "poll": 3,
              "response": {
                "task_id": "async-pay-001",
                "status": "running",
                "result": {
                  "progress": 75,
                  "processed": 1125,
                  "failed": 2,
                  "estimated_completion": "2024-12-31T12:15:00Z"
                }
              }
            },
            {
              "poll": 4,
              "response": {
                "task_id": "async-pay-001",
                "status": "completed",
                "result": {
                  "progress": 100,
                  "processed": 1500,
                  "failed": 5,
                  "total_amount_processed": 47500.00,
                  "currency": "USD"
                },
                "receipt": {
                  "receipt_id": "receipt-async-001-complete",
                  "task_id": "async-pay-001",
                  "agent_id": "agent-payment",
                  "action_taken": "payment.process.async_completed",
                  "resource_touched": "batch/payment-completed",
                  "policy_checks": ["all_transactions_verified"],
                  "timestamp": "2024-12-31T12:14:30Z",
                  "result_hash": "hash_async_complete",
                  "signature": "sig_async_complete"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "DB Query with Long-Running Analysis",
      "description": "Async database read requiring aggregation across multiple tables",
      "workflow": [
        {
          "step": 1,
          "action": "dispatch",
          "request": {
            "capability": "dbread.aggregate",
            "envelope": {
              "task_id": "async-db-001",
              "requester_identity": { "type": "agent", "id": "analytics-agent", "tenant_id": "tenant-abc" },
              "target_agent": "agent-dbread",
              "intent": "Aggregate sales data across multiple regions",
              "constraints": {
                "common": {
                  "resource_ids": ["sales_2024_q1", "sales_2024_q2", "sales_2024_q3", "sales_2024_q4"],
                  "limit": 100000
                },
                "domain": {
                  "aggregation_type": "sum",
                  "group_by": ["region", "product_category"],
                  "filters": {
                    "date_range": "2024-01-01 to 2024-12-31",
                    "min_transaction": 10
                  }
                }
              },
              "risk_class": "medium",
              "delegation_token": "tok_db_agg",
              "requested_output_mode": "structured_only"
            },
            "negotiation": {
              "schema_version": "1.0.0",
              "delivery_mode": "async"
            }
          },
          "expected_response": {
            "status": "accepted",
            "result": {
              "task_id": "async-db-001",
              "status": "running",
              "structured_output": {
                "execution_mode": "async",
                "tables_to_scan": 4,
                "estimated_rows": 85000,
                "estimated_completion": "2024-12-31T12:45:00Z"
              },
              "followup_required": true
            }
          }
        },
        {
          "step": 2,
          "action": "poll_status",
          "request": {
            "task_id": "async-db-001"
          },
          "expected_response": {
            "task_id": "async-db-001",
            "status": "completed",
            "result": {
              "summary": "Aggregated sales data across 4 regions",
              "structured_output": {
                "regions": [
                  {
                    "region": "North America",
                    "total_sales": 12500000,
                    "product_categories": [
                      { "category": "Electronics", "total": 5000000 },
                      { "category": "Clothing", "total": 3500000 },
                      { "category": "Home", "total": 4000000 }
                    ]
                  },
                  {
                    "region": "Europe",
                    "total_sales": 9800000,
                    "product_categories": [
                      { "category": "Electronics", "total": 4200000 },
                      { "category": "Clothing", "total": 3800000 },
                      { "category": "Home", "total": 1800000 }
                    ]
                  },
                  {
                    "region": "Asia Pacific",
                    "total_sales": 11200000,
                    "product_categories": [
                      { "category": "Electronics", "total": 7500000 },
                      { "category": "Clothing", "total": 2200000 },
                      { "category": "Home", "total": 1500000 }
                    ]
                  },
                  {
                    "region": "Latin America",
                    "total_sales": 4500000,
                    "product_categories": [
                      { "category": "Electronics", "total": 1800000 },
                      { "category": "Clothing", "total": 1500000 },
                      { "category": "Home", "total": 1200000 }
                    ]
                  }
                ],
                "total_sales_all_regions": 38000000,
                "rows_processed": 84532
              },
              "followup_required": false
            },
            "receipt": {
              "receipt_id": "receipt-db-async-001",
              "task_id": "async-db-001",
              "agent_id": "agent-dbread",
              "action_taken": "dbread.aggregate.completed",
              "resource_touched": "analytics/sales_aggregated",
              "policy_checks": ["data_access_approved", "aggregation_complete"],
              "timestamp": "2024-12-31T12:43:15Z",
              "result_hash": "hash_db_agg_complete",
              "signature": "sig_db_agg_complete"
            }
          }
        }
      ]
    },
    {
      "name": "Approval Workflow with Async Execution",
      "description": "Task requiring approval before async execution",
      "workflow": [
        {
          "step": 1,
          "action": "dispatch",
          "request": {
            "capability": "crm.update",
            "envelope": {
              "task_id": "async-crm-001",
              "requester_identity": { "type": "user", "id": "user-sales-mgr", "tenant_id": "tenant-abc" },
              "target_agent": "agent-crm",
              "intent": "Update customer records with new segmentation",
              "constraints": {
                "common": {
                  "resource_ids": ["customer_base"],
                  "approval_required": true
                },
                "domain": {
                  "segmentation_rule": "high_value_customers",
                  "update_fields": ["segment", "lifetime_value", "last_contact"]
                }
              },
              "risk_class": "high",
              "delegation_token": "tok_crm_pending",
              "requested_output_mode": "summary"
            }
          },
          "expected_response": {
            "status": "requires_approval",
            "result": {
              "task_id": "async-crm-001",
              "status": "awaiting_approval",
              "structured_output": {
                "approval_reference": "apr_crm_001",
                "required_approvals": ["manager_approval", "compliance_approval"]
              },
              "followup_required": true,
              "escalation_reason": "CRM updates to high-value customers require manager and compliance approval"
            }
          }
        },
        {
          "step": 2,
          "action": "approve",
          "request": {
            "task_id": "async-crm-001",
            "approval_reference": "apr_crm_001",
            "capability": "crm.update",
            "envelope": { "...": "unchanged from dispatch" }
          },
          "expected_response": {
            "status": "approved",
            "result": {
              "task_id": "async-crm-001",
              "status": "running",
              "structured_output": {
                "execution_mode": "async",
                "records_to_update": 1500
              }
            }
          }
        },
        {
          "step": 3,
          "action": "poll_status",
          "request": {
            "task_id": "async-crm-001"
          },
          "expected_response": {
            "task_id": "async-crm-001",
            "status": "completed",
            "result": {
              "summary": "Updated customer segmentation for 1500 high-value customers",
              "structured_output": {
                "records_updated": 1500,
                "records_skipped": 12,
                "compliance_logged": true
              }
            }
          }
        }
      ]
    }
  ]
}