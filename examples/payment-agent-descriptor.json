      "required_auth_scheme": "signed_request",
      "schema_version": "1.1.0",
      "supported_schema_versions": ["1.0.0", "1.1.0"],
      "preferred_schema_version": "1.1.0",
      "translation_targets": [
        {
          "from": "1.0.0",
          "to": "1.1.0",
