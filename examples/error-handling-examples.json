{
  "title": "Error Handling Example - MAP Protocol",
  "description": "Demonstrates various error scenarios and proper error handling",
  "examples": [
    {
      "scenario": "Agent Not Found",
      "request": {
        "capability": "payment.process",
        "envelope": {
          "task_id": "task-error-001",
          "requester_identity": { "type": "user", "id": "user-123", "tenant_id": "tenant-abc" },
          "target_agent": "nonexistent-agent",
          "intent": "Process payment",
          "constraints": {},
          "risk_class": "low",
          "delegation_token": "tok_xyz",
          "requested_output_mode": "full"
        }
      },
      "response": {
        "ok": false,
        "error": {
          "code": "agent_not_found",
          "message": "Target agent 'nonexistent-agent' not found in registry",
          "retryable": false,
          "status": 404,
          "details": {
            "category": "not_found",
            "field": "target_agent",
            "value": "nonexistent-agent",
            "context": {
              "available_agents": ["agent-payment", "agent-dbread", "agent-crm"]
            }
          },
          "request_id": "req-error-001"
        }
      }
    },
    {
      "scenario": "Rate Limit Exceeded",
      "request": {
        "capability": "payment.process",
        "envelope": {
          "task_id": "task-error-002",
          "requester_identity": { "type": "service", "id": "service-456", "tenant_id": "tenant-abc" },
          "target_agent": "agent-payment",
          "intent": "Process batch payment",
          "constraints": {},
          "risk_class": "medium",
          "delegation_token": "tok_batch",
          "requested_output_mode": "summary"
        }
      },
      "response": {
        "ok": false,
        "error": {
          "code": "rate_limit_exceeded",
          "message": "Rate limit exceeded for MAP mutating requests",
          "retryable": true,
          "status": 429,
          "details": {
            "category": "rate_limit",
            "scope": "tenant",
            "retry_after_ms": 1000,
            "limit": 100,
            "window": "60s"
          },
          "request_id": "req-error-002"
        }
      }
    },
    {
      "scenario": "Policy Denied",
      "request": {
        "capability": "payment.process",
        "envelope": {
          "task_id": "task-error-003",
          "requester_identity": { "type": "user", "id": "user-789", "tenant_id": "tenant-abc" },
          "target_agent": "agent-payment",
          "intent": "Process high-value payment",
          "constraints": {
            "common": {
              "max_amount": 100000,
              "environment": "production"
            }
          },
          "risk_class": "critical",
          "delegation_token": "tok_large",
          "requested_output_mode": "full"
        }
      },
      "response": {
        "ok": false,
        "error": {
          "code": "policy_denied",
          "message": "Payment amount exceeds auto-approval threshold",
          "retryable": false,
          "status": 403,
          "details": {
            "category": "authorization",
            "context": {
              "risk_class": "critical",
              "max_amount": 100000,
              "threshold": 1000,
              "policy_checks": ["payment_threshold_exceeded"]
            }
          },
          "request_id": "req-error-003"
        }
      }
    },
    {
      "scenario": "Schema Validation Failed",
      "request": {
        "capability": "payment.process",
        "envelope": {
          "task_id": "task-error-004",
          "requester_identity": { "type": "user", "id": "user-999" },
          "target_agent": "agent-payment",
          "intent": "Process payment",
          "constraints": null,
          "risk_class": "invalid_risk",
          "delegation_token": "tok_abc",
          "requested_output_mode": "full"
        }
      },
      "response": {
        "ok": false,
        "error": {
          "code": "schema_validation_failed",
          "message": "Validation failed: risk_class must be one of [low, medium, high, critical], constraints must be object",
          "retryable": false,
          "status": 400,
          "details": {
            "category": "validation",
            "validation_errors": [
              {
                "field": "risk_class",
                "message": "must be one of [low, medium, high, critical]",
                "code": "schema_validation_failed",
                "context": {
                  "field_path": "envelope.risk_class",
                  "value": "invalid_risk",
                  "schema_path": "https://map-spec.dev/schemas/task-envelope.schema.json#/properties/risk_class"
                }
              },
              {
                "field": "constraints",
                "message": "must be object",
                "code": "schema_validation_failed",
                "context": {
                  "field_path": "envelope.constraints",
                  "value": null,
                  "schema_path": "https://map-spec.dev/schemas/task-envelope.schema.json#/properties/constraints"
                }
              }
            ],
            "schema_ref": "https://map-spec.dev/schemas/task-envelope.schema.json"
          },
          "request_id": "req-error-004"
        }
      }
    },
    {
      "scenario": "Token Expired",
      "request": {
        "capability": "dbread.query",
        "envelope": {
          "task_id": "task-error-005",
          "requester_identity": { "type": "agent", "id": "agent-query", "tenant_id": "tenant-abc" },
          "target_agent": "agent-dbread",
          "intent": "Query database",
          "constraints": {
            "common": {
              "resource_id": "orders table"
            }
          },
          "risk_class": "medium",
          "delegation_token": "tok_expired",
          "requested_output_mode": "structured_only"
        }
      },
      "response": {
        "ok": false,
        "error": {
          "code": "token_expired",
          "message": "Delegation token has expired",
          "retryable": false,
          "status": 401,
          "details": {
            "category": "authentication",
            "context": {
              "token_issued_at": "2024-01-01T00:00:00Z",
              "token_expires_at": "2024-01-01T01:00:00Z",
              "current_time": "2024-01-01T02:00:00Z"
            }
          },
          "request_id": "req-error-005"
        }
      }
    },
    {
      "scenario": "Capability Disabled",
      "request": {
        "capability": "payment.process",
        "envelope": {
          "task_id": "task-error-006",
          "requester_identity": { "type": "service", "id": "service-payment", "tenant_id": "tenant-abc" },
          "target_agent": "agent-payment",
          "intent": "Process payment",
          "constraints": {},
          "risk_class": "low",
          "delegation_token": "tok_valid",
          "requested_output_mode": "full"
        }
      },
      "response": {
        "ok": false,
        "error": {
          "code": "capability_disabled",
          "message": "Capability is disabled in runtime controls: payment.process",
          "retryable": false,
          "status": 403,
          "details": {
            "category": "authorization",
            "disabled": {
              "disabled_at": "2024-03-15T10:30:00Z",
              "disabled_by": "admin@company.com",
              "reason": "Maintenance window - payments disabled until 12:00 UTC"
            }
          },
          "request_id": "req-error-006"
        }
      }
    },
    {
      "scenario": "Approval Required",
      "request": {
        "capability": "payment.process",
        "envelope": {
          "task_id": "task-error-007",
          "requester_identity": { "type": "user", "id": "user-high-value", "tenant_id": "tenant-abc" },
          "target_agent": "agent-payment",
          "intent": "Process high-value payment requiring approval",
          "constraints": {
            "common": {
              "max_amount": 5000,
              "approval_required": true
            }
          },
          "risk_class": "high",
          "delegation_token": "tok_approval",
          "requested_output_mode": "full"
        }
      },
      "response": {
        "ok": false,
        "error": {
          "code": "approval_required",
          "message": "High risk operations require human approval",
          "retryable": false,
          "status": 202,
          "details": {
            "category": "authorization",
            "approval_reference": "apr_abc123",
            "context": {
              "risk_class": "high",
              "required_approvals": ["human_review"]
            }
          },
          "request_id": "req-error-007"
        }
      }
    }
  ]
}