{
  "name": "micro-agent-protocol",
  "version": "2026.5.14",
  "description": "Micro Agent Protocol (MAP) - Open standard for AI assistant to micro-agent delegation",
  "type": "module",
  "workspaces": [
    "packages/*",
    "conformance"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "node --test --test-concurrency=1 dist/src/test/*.test.js",
    "test:policy": "node --test dist/src/test/policy.test.js",
    "test:benchmark": "node --test dist/src/test/benchmark.test.js",
    "test:simple": "node --test dist/src/test/map-simple.test.js",
    "verify:reference": "npm run check && npm run build && npm test",
    "conformance:reference": "npm run build && node dist/src/conformance.js",
    "conformance:profiles": "npm run build && node dist/src/conformance-profiles.js",
    "conformance:trust": "npm run build && node dist/src/conformance-trust.js",
    "conformance:fixtures": "npm run build && node dist/src/conformance-fixtures.js",
    "conformance:errors": "npm run build && node dist/src/conformance-errors.js",
    "conformance:contract": "npm run build && node dist/src/conformance-contract.js",
    "conformance:api-surface": "npm run build && node dist/src/conformance-api-surface.js",
    "conformance:all": "npm run conformance:reference && npm run conformance:profiles && npm run conformance:trust && npm run conformance:fixtures && npm run conformance:errors && npm run conformance:contract && npm run conformance:api-surface",
    "load:reference": "npm run build && node dist/src/load-test.js",
    "dev:server": "tsx src/server-main.ts",
    "dev:demo-server": "tsx demo/server.ts",
    "demo:payment": "tsx demo/demo-payment.ts",
    "demo:db-read": "tsx demo/demo-db-read.ts",
    "demo:full": "tsx demo/demo-full-flow.ts",
    "sdk:typescript": "cd packages/typescript && npm run check && npm run build && npm run test",
    "sdk:python": "cd packages/python && pip install -e .",
    "sdk:go": "cd packages/go && go build ./...",
    "protocols:clone": "cd references/protocols && git clone https://github.com/modelcontextprotocol/specification.git mcp || true && git clone https://github.com/google/A2A.git a2a || true",
    "conformance:test": "cd conformance && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "ajv": "^8.17.1",
    "eslint": "^10.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.59.3"
  }
}
