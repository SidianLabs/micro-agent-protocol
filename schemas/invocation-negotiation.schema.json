{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SidianLabs/micro-agent-protocol/raw/main/schemas/invocation-negotiation.schema.json",
  "title": "MAP Invocation Negotiation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requested",
    "selected"
  ],
  "properties": {
    "requested": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_mode",
        "delivery_mode"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "output_mode": {
          "type": "string",
          "enum": [
            "full",
            "summary",
            "structured_only",
            "receipt_only",
            "redacted",
            "debug"
          ]
        },
        "delivery_mode": {
          "type": "string",
          "enum": [
            "sync",
            "async"
          ]
        }
      }
    },
    "selected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "output_mode",
        "delivery_mode"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "output_mode": {
          "type": "string",
          "enum": [
            "full",
            "summary",
            "structured_only",
            "receipt_only",
            "redacted",
            "debug"
          ]
        },
        "delivery_mode": {
          "type": "string",
          "enum": [
            "sync",
            "async"
          ]
        }
      }
    },
    "provider_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "schema_translated"
        ]
      },
      "default": []
    }
  }
}