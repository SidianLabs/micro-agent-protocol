{
  "name": "@sidianlabs/map-sdk",
  "version": "2026.05.14",
  "description": "Official TypeScript/Node.js SDK for Micro Agent Protocol (MAP)",
  "license": "Apache-2.0",
  "author": "Sidian Labs",
  "keywords": [
    "map",
    "micro-agent-protocol",
    "ai",
    "agents",
    "delegation",
    "policy"
  ],
  "homepage": "https://github.com/SidianLabs/micro-agent-protocol#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/SidianLabs/micro-agent-protocol.git",
    "directory": "packages/typescript"
  },
  "bugs": {
    "url": "https://github.com/SidianLabs/micro-agent-protocol/issues"
  },
  "preview": "This is a preview release. API may change. See https://github.com/SidianLabs/micro-agent-protocol/blob/main/docs/preview-status.md",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transport": {
      "import": "./dist/transport/index.js",
      "types": "./dist/transport/index.d.ts"
    },
    "./signing": {
      "import": "./dist/signing/index.js",
      "types": "./dist/signing/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "schema:sync": "node ../../tools/generate-typescript-schemas.mjs",
    "types:sync": "node ../../tools/sync-typescript-map-types.mjs",
    "protocol:sync": "npm run schema:sync && npm run types:sync",
    "prebuild": "npm run protocol:sync",
    "build": "tsc -p tsconfig.build.json",
    "precheck": "npm run protocol:sync",
    "check": "tsc --noEmit",
    "pretest": "npm run protocol:sync",
    "test": "node --test test/*.test.ts",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "map",
    "micro-agent-protocol",
    "ai",
    "agents",
    "delegation",
    "policy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SidianLabs/micro-agent-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/SidianLabs/micro-agent-protocol/issues"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "type": "module"
}
