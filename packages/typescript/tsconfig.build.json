{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist/**",
    "node_modules/**",
    "test/**",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}